VITE_API_URL=http://localhost:3000

# Stripe publishable key (Test mode) — https://dashboard.stripe.com/test/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key

# Optional: Google Maps (Listing map + Find map). Get a key at:
# https://console.cloud.google.com/apis/credentials → Create credentials → API key
# Enable "Maps JavaScript API" and "Geocoding API" for the project, then paste the key below.
# (Geocoding API is used when listing a space: typing country/city moves the map.)
# VITE_GOOGLE_MAPS_API_KEY=
