generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                     String    @id @default(cuid())
  email                  String    @unique
  passwordHash           String    @map("password_hash")
  name                   String
  role                   String    @default("user") @map("role")
  avatarUrl              String?   @map("avatar_url")
  professionalTitle      String?   @map("professional_title")
  bio                    String?   @db.Text
  bookingUpdatesEnabled Boolean   @default(true) @map("booking_updates_enabled")
  hostBookingUpdatesEnabled Boolean @default(true) @map("host_booking_updates_enabled")
  messageAlertsEnabled   Boolean  @default(true) @map("message_alerts_enabled")
  systemNotificationsEnabled Boolean @default(true) @map("system_notifications_enabled")
  availabilityStartTime  String?   @map("availability_start_time")
  availabilityEndTime    String?   @map("availability_end_time")
  bannedAt               DateTime? @map("banned_at")
  emailVerifiedAt        DateTime? @map("email_verified_at")
  createdAt              DateTime  @default(now()) @map("created_at")

  spacesAsHost         Space[]               @relation("HostSpaces")
  bookings             Booking[]
  reviews              Review[]
  favorites            Favorite[]
  passwordResetTokens       PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  conversations        ConversationParticipant[]
  messagesSent         Message[]             @relation("MessagesSent")
  notifications        Notification[]
}

model Conversation {
  id            String    @id @default(cuid())
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  lastMessageAt DateTime? @map("last_message_at")

  participants ConversationParticipant[]
  messages      Message[]

  @@index([lastMessageAt])
}

model ConversationParticipant {
  conversationId String   @map("conversation_id")
  userId         String   @map("user_id")
  joinedAt       DateTime @default(now()) @map("joined_at")
  lastReadAt     DateTime? @map("last_read_at")
  // Comportament de stergere per user:
  // - hiddenAt: conversatia e ascunsa in lista userului respectiv
  // - clearedAt: mesajele dinainte de momentul respectiv sunt ascunse pentru userul curent
  hiddenAt       DateTime? @map("hidden_at")
  clearedAt      DateTime? @map("cleared_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String    @id @default(cuid())
  conversationId String    @map("conversation_id")
  senderId       String    @map("sender_id")
  text           String    @db.Text
  createdAt      DateTime  @default(now()) @map("created_at")
  editedAt       DateTime? @map("edited_at")
  deletedAt      DateTime? @map("deleted_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("MessagesSent", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderId])
}

model Amenity {
  id     String         @id
  label  String
  spaces SpaceAmenity[]
}

model SpaceAmenity {
  spaceId   String @map("space_id")
  amenityId String @map("amenity_id")

  space   Space   @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  amenity Amenity @relation(fields: [amenityId], references: [id], onDelete: Cascade)

  @@id([spaceId, amenityId])
  @@index([amenityId])
  @@map("space_amenity")
}

model Space {
  id                String   @id @default(cuid())
  hostId            String   @map("host_id")
  category          String
  title             String
  location          String
  locationNorm      String   @default("") @map("location_norm")
  capacity          Int
  pricePerHour      Decimal  @map("price_per_hour") @db.Decimal(10, 2)
  squareMeters      Int?     @map("square_meters")
  description       String   @db.Text
  imageUrl          String?  @map("image_url")
  imagesJson        String?  @map("images_json") @db.Text
  isInstantBookable Boolean  @default(false) @map("is_instant_bookable")
  availabilityStartTime String? @map("availability_start_time")
  availabilityEndTime   String? @map("availability_end_time")
  sameDayBookingAllowed Boolean @default(false) @map("same_day_booking_allowed")
  minDurationHours      Int?    @map("min_duration_hours")
  maxDurationHours      Int?    @map("max_duration_hours")
  maxAdvanceBookingDays Int?    @map("max_advance_booking_days")
  cancellationPolicy    String? @map("cancellation_policy")
  cleaningFeeCents      Int?    @map("cleaning_fee_cents")
  equipmentFeeCents     Int?    @map("equipment_fee_cents")
  weeklyScheduleEnabled Boolean @default(false) @map("weekly_schedule_enabled")
  hostLastSeenBookingsAt DateTime? @map("host_last_seen_bookings_at")
  status            String   @default("active") @map("status")
  latitude          Float?
  longitude         Float?
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  host      User           @relation("HostSpaces", fields: [hostId], references: [id], onDelete: Cascade)
  bookings  Booking[]
  reviews   Review[]
  favorites Favorite[]
  amenities    SpaceAmenity[]
  bannedDays   SpaceBannedDay[]
  blockedDates SpaceBlockedDate[]

  @@index([hostId])
  @@index([status, category])
  @@index([status, pricePerHour])
  @@index([status, capacity])
  @@index([status, squareMeters])
  @@index([status, locationNorm])
  @@index([status, createdAt(sort: Desc)])
}

model SpaceBannedDay {
  spaceId   String @map("space_id")
  dayOfWeek String @map("day_of_week")

  space Space @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@id([spaceId, dayOfWeek])
  @@map("space_banned_day")
}

model SpaceBlockedDate {
  id        String   @id
  spaceId   String   @map("space_id")
  startDate DateTime @map("start_date") @db.Date
  endDate   DateTime @map("end_date") @db.Date
  createdAt DateTime @default(now()) @map("created_at")

  space Space @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@index([spaceId, startDate])
  @@map("space_blocked_date")
}

model Booking {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  spaceId    String   @map("space_id")
  date       DateTime @db.Date
  startTime    String @map("start_time")
  endTime      String @map("end_time")
  startMinutes Int @map("start_minutes")
  endMinutes   Int @map("end_minutes")
  status       String @default("pending")
  totalPrice Decimal  @map("total_price") @db.Decimal(10, 2)
  cleaningFeeCents Int? @map("cleaning_fee_cents")
  equipmentFeeCents Int? @map("equipment_fee_cents")
  createdAt  DateTime @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  space Space @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@index([spaceId, date])
  @@index([userId])
}

model Review {
  id            String   @id @default(cuid())
  spaceId       String   @map("space_id")
  userId        String   @map("user_id")
  rating        Float
  text          String   @db.Text
  cleanliness   Int?
  communication Int?
  location      Int?
  value         Int?
  createdAt     DateTime @default(now()) @map("created_at")

  space Space @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([spaceId])
}

model Favorite {
  userId  String @map("user_id")
  spaceId String @map("space_id")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  space Space @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@id([userId, spaceId])
  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model NewsletterSubscriber {
  id           String   @id @default(cuid())
  email        String   @unique
  subscribedAt DateTime @default(now()) @map("subscribed_at")

  @@map("newsletter_subscriber")
}

model Notification {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  type      String    @map("type")
  title     String    @map("title")
  message   String    @db.Text
  dataJson  String?   @map("data_json") @db.Text
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, readAt])
}
